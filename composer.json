{
    "name": "powerticmkt/powertic-sms-bundle",
    "description": "Mautic SMS Plugin with HTTP Webhook and RabbitMQ support",
    "type": "mautic-plugin",
    "keywords": [
        "mautic",
        "plugin",
        "webhook",
        "sms",
        "rabbitmq",
        "amqp"
    ],
    "extra": {
        "install-directory-name": "PowerticSmsBundle"
    },
    "minimum-stability": "dev",
    "require": {
        "mautic/core-lib": "^7.0"
    },
    "suggest": {
        "php-amqplib/php-amqplib": "Required for RabbitMQ transport support (^3.0)"
    }
}